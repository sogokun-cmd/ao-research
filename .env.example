# ── AOリサーチ — 環境変数サンプル ───────────────────────────
# このファイルをコピーして .env を作成してください
# cp .env.example .env

# Anthropic API（必須）
ANTHROPIC_API_KEY=

# Google OAuth2（Google Cloud Console で取得）
# リダイレクト URI: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT シークレット（openssl rand -hex 32 で生成）
JWT_SECRET_KEY=

# Notion（Notion 保存機能を使う場合のみ）
NOTION_TOKEN=
